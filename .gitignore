# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (nunca subir secretos a GitHub)
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# sqlite local (se genera con `npm run db:setup`)
/prisma/dev.db
/prisma/dev.db-journal

# imágenes de productos subidas en cada máquina
/public/uploads/productos/*
!/public/uploads/productos/.gitkeep
