# Copiar a ".env" en la raíz del proyecto (nunca commitear .env).
# En Windows PowerShell: Copy-Item .env.example .env

# SQLite: el archivo se crea en prisma/dev.db al correr migraciones
DATABASE_URL="file:./dev.db"

# Secreto para firmar cookies de sesión (generá uno distinto en producción)
# Ejemplo Node: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"

# URL pública de la app (desarrollo local)
NEXTAUTH_URL="http://localhost:3000"
